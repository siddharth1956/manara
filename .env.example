# Copernicus credentials — only used by app/services/copernicus_service.py
# and the scripts/download_* data-pipeline scripts, not by the live
# FastAPI backend (app/main.py never imports that module). Needed if
# you're rebuilding the indexed corpus from scratch; not needed to run
# or deploy the API itself.
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=

# Comma-separated list of origins allowed to call the API (CORS).
# Defaults to the Vite dev server's origin if unset — only needs
# setting in production, to your deployed frontend's real URL.
ALLOWED_ORIGINS=https://your-manara-app.vercel.app
