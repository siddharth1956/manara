# Python
__pycache__/
*.py[cod]
*.so

# Virtual environments
venv/
.venv/
env/

# Environment variables
.env

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# Python cache
.pytest_cache/
.mypy_cache/

# Models
models/
*.gguf

# Ollama
ollama/

# Embeddings — data/embeddings/faiss_index.bin and bm25_index.pkl
# (the two prebuilt indexes retriever.py actually loads at request
# time) are deliberately NOT listed here, so they stay tracked; only
# the raw embeddings.npy (a build-time intermediate, not read at
# request time) is excluded. Explicit-exclude rather than
# wildcard-then-negate — verified that `data/embeddings/*` +
# `!data/embeddings/faiss_index.bin` does NOT reliably re-include the
# file with this git version, despite being git's textbook documented
# pattern for this.
data/embeddings/embeddings.npy
cache/

# Generated evaluation files
evaluation/*.png
evaluation/*.csv
evaluation/*.json
evaluation/*.md
evaluation/*.txt

# Jupyter
.ipynb_checkpoints/

# Logs
*.log

# Large datasets — these are data-pipeline intermediates (see
# CLAUDE.md's data pipeline section), never read at request time by
# the deployed backend, which only loads data/processed/search_corpus.csv
# (844KB — deliberately NOT excluded here, unlike these).
data/raw/
data/processed/manara_dataset.csv
data/processed/dubai_roads.csv
data/processed/dubai_roads.geojson

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# Stale nested checkout — its own separate git repo, not part of this
# project (see CLAUDE.md's repo layout note).
manara/